<style>
  :root {
    --bg: #fbf9f4;
    --card-bg: #fffdf8;
    --text: #2b2b28;
    --muted: #6b6a63;
    --border: #ded7c4;
    --accent: #8a6d3b;
    --risk-high: #b3452b;
    --risk-moderate: #b08628;
    --risk-low: #4a7a5a;
    --risk-unknown: #8a8578;
    --flagged-bg: #fbeee9;
    --flagged-border: #c0603f;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #211f1a;
      --card-bg: #2a2823;
      --text: #ece7da;
      --muted: #a49d8a;
      --border: #4a4638;
      --accent: #d3b57f;
      --risk-high: #e08064;
      --risk-moderate: #dcb45f;
      --risk-low: #82b494;
      --risk-unknown: #9b9686;
      --flagged-bg: #3a2a24;
      --flagged-border: #d3805f;
    }
  }
  * { box-sizing: border-box; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: var(--bg);
    color: var(--text);
    max-width: 960px;
    margin: 0 auto;
    padding: 24px 16px 64px;
    line-height: 1.55;
    font-size: 16px;
  }
  h1 { font-size: 1.5rem; margin-bottom: 4px; }
  h2 { font-size: 1.15rem; margin: 0; }
  a { color: var(--accent); }
  .meta { color: var(--muted); font-size: 0.9rem; margin-bottom: 20px; }
  .back { display: inline-block; margin-bottom: 16px; text-decoration: none; }
  .overall-summary {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 8px;
    padding: 14px 16px;
    margin: 4px 0 20px;
    font-size: 1.02rem;
  }
  .category-summary {
    color: var(--muted);
    font-style: italic;
    margin: -4px 0 12px;
    font-size: 0.94rem;
  }
  .pros-cons {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px 16px;
    margin: 0 0 14px;
    font-size: 0.88rem;
  }
  .pros-cons ul { list-style: none; padding: 0; margin: 0; }
  .pros-cons li {
    padding: 2px 0 2px 18px;
    position: relative;
  }
  .pros li::before {
    content: "+";
    position: absolute; left: 2px;
    color: var(--risk-low);
    font-weight: 700;
  }
  .cons li::before {
    content: "\2212";
    position: absolute; left: 2px;
    color: var(--risk-high);
    font-weight: 700;
  }
  @media (max-width: 480px) {
    .pros-cons { grid-template-columns: 1fr; }
  }
  .completion-badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 999px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    font-size: 0.85rem;
    color: var(--muted);
    margin-bottom: 20px;
  }
  .scorecard {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 10px;
    margin-bottom: 24px;
  }
  .scorecard-item {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px 12px;
  }
  .scorecard-item .label { font-size: 0.78rem; color: var(--muted); }
  .scorecard-item .value { font-size: 1.1rem; font-weight: 600; }
  nav.toc {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 14px;
    font-size: 0.88rem;
    margin-bottom: 28px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }
  nav.toc a { text-decoration: none; }
  details.category {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    margin-bottom: 12px;
    padding: 4px 16px;
  }
  details.category summary {
    cursor: pointer;
    padding: 12px 0;
    font-weight: 600;
    list-style: none;
  }
  details.category summary::-webkit-details-marker { display: none; }
  details.category summary::before {
    content: "▸ ";
    color: var(--muted);
  }
  details.category[open] summary::before {
    content: "▾ ";
  }
  .field-table { width: 100%; border-collapse: collapse; margin: 8px 0 16px; }
  .field-table th, .field-table td {
    text-align: left;
    padding: 8px 8px;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
    font-size: 0.94rem;
  }
  .field-table th { color: var(--muted); font-weight: 500; font-size: 0.82rem; }
  .field-table--fields th:nth-child(1), .field-table--fields td:nth-child(1) { width: 20%; }
  .field-table--fields th:nth-child(2), .field-table--fields td:nth-child(2) { width: 58%; }
  .field-table--fields th:nth-child(3), .field-table--fields td:nth-child(3) { width: 22%; }
  .field-label { white-space: nowrap; color: var(--muted); }
  .source-link { font-size: 0.82rem; white-space: nowrap; }
  .caveat { color: var(--muted); font-size: 0.85rem; }
  .placeholder { color: var(--muted); font-style: italic; }
  .flagged-row td {
    background: var(--flagged-bg);
    border-left: 3px solid var(--flagged-border);
  }
  .risk-badge {
    display: inline-block;
    padding: 1px 8px;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 600;
    color: #fff;
    margin-right: 6px;
    vertical-align: middle;
  }
  .table-scroll { overflow-x: auto; }
  .table-scroll table { min-width: 480px; }
  .chart-wrap { margin: 12px 0 20px; }
  .chart-wrap svg { max-width: 100%; height: auto; }
  ul.city-list { list-style: none; padding: 0; }
  ul.city-list li {
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
  }
  ul.city-list a { text-decoration: none; font-weight: 600; font-size: 1.05rem; }
  .county { color: var(--muted); font-size: 0.88rem; }
  .empty { color: var(--muted); }
  @media (max-width: 480px) {
    body { padding: 16px 12px 48px; font-size: 15px; }
    .scorecard { grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); }
  }
</style>
