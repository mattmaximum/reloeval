<!doctype html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Relocation Evaluator</title>
{% include "_style.html.j2" %}
</head>
<body>
<h1>Relocation Evaluator</h1>

{% if cities|length >= 2 %}
<p><a href="compare.html">&#8646; Compare two cities side by side</a></p>
{% endif %}

{% if cities %}
<ul class="city-list">
{% for city in cities %}
  <li class="city-row">
    <div class="city-info">
      <a href="{{ city.href }}">{{ city.city }}, {{ city.state }}</a><br>
      <span class="county">{{ city.county }} &middot; {{ city.completion.valid }}/{{ city.completion.total }} fields ({{ city.completion.percent }}%)</span>
    </div>
    {% if city.lens_scores %}
    <div class="fit-scores city-fit-scores">
    {% for lens_key, lens in city.lens_scores.items() %}
      {% if lens.state == "scored" %}
        {% set css_class = "fit-strong" if lens.fit_label == "Strong Fit" else ("fit-good" if lens.fit_label == "Good Fit" else "fit-weak") %}
        <span class="fit-badge has-tooltip {{ css_class }}" tabindex="0"><span class="fit-lens-name">{{ lens.label }}:</span> {{ lens.fit_label }}{% if lens.reason %}<span class="tooltip-text">{{ lens.reason }}</span>{% endif %}</span>
      {% elif lens.state == "dealbreaker" %}
        <span class="fit-badge has-tooltip fit-dealbreaker" tabindex="0"><span class="fit-lens-name">{{ lens.label }}:</span> Dealbreaker{% if lens.reason %}<span class="tooltip-text">{{ lens.reason }}</span>{% endif %}</span>
      {% elif lens.state == "needs_data" %}
        <span class="fit-badge has-tooltip fit-needs-data" tabindex="0"><span class="fit-lens-name">{{ lens.label }}:</span> Needs data{% if lens.reason %}<span class="tooltip-text">{{ lens.reason }}</span>{% endif %}</span>
      {% endif %}
    {% endfor %}
    </div>
    {% endif %}
  </li>
{% endfor %}
</ul>
{% else %}
<p class="empty">No cities evaluated yet.</p>
{% endif %}
</body>
</html>
