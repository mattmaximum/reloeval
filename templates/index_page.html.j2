<!doctype html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Relocation Evaluator</title>
{% include "_style.html.j2" %}
</head>
<body>
<h1>Relocation Evaluator</h1>

<p class="site-intro">
A personal tool comparing US cities across 83 data points &mdash; schools, safety, climate,
infrastructure, land/legal, self-sufficiency &mdash; using live web search and an LLM. Public in
case it helps someone else.
</p>
<ul class="site-intro-notes">
<li>Every data point is researched by an AI model, not a person &mdash; it can and does get
things wrong. Check the source link before relying on anything important. Spot an error?
<a href="https://github.com/mattmaximum/reloeval/issues/new/choose">Let me know</a>.</li>
<li>Adding cities is closed to the public &mdash; it costs real money to run (that could change
in the future).</li>
<li>The Family Fit and Self-Sufficiency scores are deliberately subjective &mdash; reflecting one
family's priorities and weightings, not an objective ranking. That family has several young
children, isn't chasing an off-grid or isolated location, and accepts some risk tradeoffs. Yours
will likely differ &mdash; feel free to ignore the scores and just read the data.</li>
</ul>

{% if cities|length >= 2 %}
<div class="list-controls">
  <a class="button-link" href="compare.html">Compare 2 cities</a>
  <div class="sort-controls">
    <label for="city-sort">Sort by:</label>
    <select id="city-sort">
      <option value="default">Default order</option>
      <option value="best-overall-desc">Best Overall Fit (Family + Self-Sufficiency)</option>
      <option value="bd-desc">BD Score: High to Low</option>
      <option value="family-desc">Family Fit: High to Low</option>
      <option value="self-suff-desc">Self-Sufficiency: High to Low</option>
      <option value="state-asc">State (A-Z)</option>
      <option value="recent-desc">Most Recently Added</option>
    </select>
  </div>
</div>
{% endif %}

{% macro fit_cell(lens, emoji) %}
  {% if lens.state == "scored" %}
    {% set css_class = "fit-strong" if lens.fit_label == "Strong Fit" else ("fit-good" if lens.fit_label == "Good Fit" else "fit-weak") %}
    <span class="fit-badge has-tooltip {{ css_class }}" tabindex="0">{{ emoji }} {{ lens.fit_label }}{% if lens.reason %}<span class="tooltip-text">{{ lens.reason }}</span>{% endif %}</span>
  {% elif lens.state == "dealbreaker" %}
    <span class="fit-badge has-tooltip fit-dealbreaker" tabindex="0">{{ emoji }} Dealbreaker{% if lens.reason %}<span class="tooltip-text">{{ lens.reason }}</span>{% endif %}</span>
  {% elif lens.state == "needs_data" %}
    <span class="fit-badge has-tooltip fit-needs-data" tabindex="0">{{ emoji }} Needs data{% if lens.reason %}<span class="tooltip-text">{{ lens.reason }}</span>{% endif %}</span>
  {% endif %}
{% endmacro %}

{% if cities %}
<div class="city-row city-header-row">
  <div>City, State</div>
  <div>BD Score<span class="info-icon" tabindex="0">&#9432;<span class="tooltip-text">Elevation (ft) + distance to the ocean (mi), added together. Higher is generally more inland/elevated. The color bands are fixed personal thresholds, not an objective scale.</span></span></div>
  <div>County</div>
  <div>Fields<span class="info-icon" tabindex="0">&#9432;<span class="tooltip-text">Fields with data out of the total tracked &mdash; measures completeness, not quality.</span></span></div>
  <div>Family Fit</div>
  <div>Self-Sufficiency</div>
</div>
<ul class="city-list">
{% for city in cities %}
  <li class="city-row"
      data-family-score="{{ city.lens_scores.family.score if city.lens_scores.family.state == 'scored' else -1 }}"
      data-self-suff-score="{{ city.lens_scores.self_sufficiency.score if city.lens_scores.self_sufficiency.state == 'scored' else -1 }}"
      data-bd-score="{{ city.bd_score_field.value if city.bd_score_field and city.bd_score_field.status == 'valid' else -1 }}"
      data-state="{{ city.state }}"
      data-city="{{ city.city }}"
      data-first-evaluated="{{ city.first_evaluated_date or '0000-00-00' }}">
    <div class="city-info">
      <a href="{{ city.href }}">{{ city.city }}, {{ city.state }}</a>
    </div>
    <div class="city-bd-score">{% if city.bd_score_field and city.bd_score_field.status == "valid" %}{{ city.bd_score_field.display_value }}{% else %}<span class="placeholder">Not yet evaluated</span>{% endif %}</div>
    <div class="city-county">{{ city.county }}</div>
    <div class="city-fields">{{ city.completion.valid }}/{{ city.completion.total }} ({{ city.completion.percent }}%)</div>
    <div class="city-fit-cell">{{ fit_cell(city.lens_scores.family, "👨‍👩‍👧") }}</div>
    <div class="city-fit-cell">{{ fit_cell(city.lens_scores.self_sufficiency, "🛡️") }}</div>
  </li>
{% endfor %}
</ul>
{% else %}
<p class="empty">No cities evaluated yet.</p>
{% endif %}

{% if cities %}
<p><a href="scoring.html">&#9432; How the Fit scores are calculated</a></p>
{% endif %}

<p class="caveat">Protected by MIT Licensing.</p>

{% if cities|length >= 2 %}
<script>
(function () {
  var citySort = document.getElementById("city-sort");
  var list = document.querySelector("ul.city-list");
  if (!citySort || !list) return;

  var originalOrder = Array.prototype.slice.call(list.children);

  var sorters = {
    "default": function (a, b) { return originalOrder.indexOf(a) - originalOrder.indexOf(b); },
    "best-overall-desc": function (a, b) {
      var aMin = Math.min(parseFloat(a.dataset.familyScore), parseFloat(a.dataset.selfSuffScore));
      var bMin = Math.min(parseFloat(b.dataset.familyScore), parseFloat(b.dataset.selfSuffScore));
      return bMin - aMin;
    },
    "bd-desc": function (a, b) { return parseFloat(b.dataset.bdScore) - parseFloat(a.dataset.bdScore); },
    "family-desc": function (a, b) { return parseFloat(b.dataset.familyScore) - parseFloat(a.dataset.familyScore); },
    "self-suff-desc": function (a, b) { return parseFloat(b.dataset.selfSuffScore) - parseFloat(a.dataset.selfSuffScore); },
    "state-asc": function (a, b) {
      var cmp = a.dataset.state.localeCompare(b.dataset.state);
      return cmp !== 0 ? cmp : a.dataset.city.localeCompare(b.dataset.city);
    },
    "recent-desc": function (a, b) { return b.dataset.firstEvaluated.localeCompare(a.dataset.firstEvaluated); },
  };

  citySort.addEventListener("change", function () {
    var items = Array.prototype.slice.call(list.children);
    items.sort(sorters[citySort.value]);
    items.forEach(function (li) { list.appendChild(li); });
  });
})();
</script>
{% endif %}
</body>
</html>
