    "water_supply": {
      "primary_water_source": {
        "value": "Bozeman relies on snowpack from the Gallatin Range for approximately 80% of its water supply, with about 40% from Hyalite Creek watershed, 40% from Bozeman Creek watershed, and 20% from a developed spring at the headwaters of Lyman Creek in the Bridger Range",
        "source_url": "https://www.bozeman.net/departments/utilities/water-conservation/drought-management",
        "fetched_date": "2026-07-24",
        "status": "valid",
        "schema_version": 1
      },
      "drought_risk": {
        "value": "High drought risk - Bozeman is semi-arid and drought-prone with an average of 16 inches of precipitation annually. The region is experiencing climate change impacts with more precipitation falling as rain instead of snow and earlier snowmelt. In 2024, the city consumed 43% of legal water rights and 60% of reliable supply during drought conditions. Montana is currently in its sixth straight year of drought conditions as of the search date",
        "source_url": "https://www.bozeman.net/departments/utilities/water-conservation/drought-management",
        "fetched_date": "2026-07-24",
        "status": "valid",
        "schema_version": 1
      },
      "well_legality": {
        "value": "Not applicable - Bozeman's water supply comes from surface water sources (creeks, reservoirs, and springs) rather than groundwater wells. The city does not rely on private well water for municipal supply",
