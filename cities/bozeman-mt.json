      },
      "water_rights_restrictions": {
        "value": "Bozeman has legal water rights of 16,517 acre-feet per year with a reliable supply of 11,920 acre-feet per year during a 1 in 50-year drought condition. The city has adopted a Drought Management Plan (updated in 2022) with tiered response measures and conservation restrictions that can be implemented when drought stages are declared",
        "source_url": "https://www.bozeman.net/departments/utilities/water-conservation/drought-management",
        "fetched_date": "2026-07-24",
        "status": "valid",
        "schema_version": 1
      },
      "backup_water_availability": {
        "value": "Hyalite Reservoir serves as primary backup storage; it was at full capacity during recent drought conditions. The City has implemented a Water Supply Optimization Tool for proactive forecasting and management. Additional water supply expansion projects are projected to add 1,575 acre-feet over the next 5 years",
        "source_url": "https://nbcmontana.com/news/local/bozeman-promotes-conservation-tools-free-irrigation-audits-as-long-term-drought-strategy",
        "fetched_date": "2026-07-24",
        "status": "valid",
        "schema_version": 1
      },
      "category_summary": {
        "value": "Bozeman relies almost entirely on snowpack-fed surface water (80% from mountain creeks), making it highly vulnerable to drought—the city consumed 60% of its reliable supply in 2024 during drought conditions while the region faces its sixth consecutive drought year with only 16 inches annual precipitation. However, the city has proactive management tools, a drought plan with tiered restrictions, and backup storage capacity in Hyalite Reservoir.",
        "source_url": null,
        "fetched_date": null,
        "status": "valid",
        "schema_version": 1
      },
